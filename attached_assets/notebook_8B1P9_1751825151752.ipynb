                 \"name\": \"Realizzazione Siti Web Aziendali Professionali\",\n                        \"description\": \"Creazione siti web professionali per aziende\"\n                    }\n                },\n                {\n                    \"@type\": \"Offer\",\n                    \"itemOffered\": {\n                        \"@type\": \"Service\",\n                        \"name\": \"Realizzazione Siti Web Economici\",\n                        \"description\": \"Siti web economici ma professionali per piccole attività\"\n                    }\n                }\n            ]\n        }\n    }\n    </script>\n\n    <!-- Header -->\n    <header class=\"header\">\n        <nav class=\"nav-container\">\n            <div class=\"nav-brand\">\n                <h1>Web Agency Italia</h1>\n                <span class=\"tagline\">Realizzazione Siti Web Professionali</span>\n            </div>\n            <ul class=\"nav-menu\">\n                <li><a href=\"#servizi\">Servizi</a></li>\n                <li><a href=\"#citta\">Città</a></li>\n                <li><a href=\"#settori\">Settori</a></li>\n                <li><a href=\"#contatti\">Contatti</a></li>\n            </ul>\n        </nav>\n    </header>\n\n    <!-- Breadcrumbs -->\n    <nav class=\"breadcrumbs\">\n        <ol>\n            <li><a href=\"/\">Home</a></li>\n            <li>Realizzazione Siti Web Aziendali Professionali</li>\n        </ol>\n    </nav>\n\n    <!-- Main Content -->\n    <main>\n        <!-- Hero Section -->\n        <section class=\"hero\">\n            <div class=\"container\">\n                <h1>Realizzazione Siti Web Aziendali Professionali</h1>\n                <h2>Creazione Siti Web Professionali Aziendali per Attività in Tutta Italia</h2>\n                <p class=\"hero-description\">\n                    Specializzati nella <strong>realizzazione siti web economici</strong> ma professionali. \n                    Creiamo siti web ottimizzati SEO per far crescere la tua 